page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  color: #333;
}

.container {
  padding: 20rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: #ddd;
}

.nickname {
  margin-top: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.points-card {
  background: linear-gradient(135deg, #1890ff, #36aaff);
  padding: 40rpx;
  border-radius: 16rpx;
  color: #fff;
  text-align: center;
  margin: 20rpx;
}

.points-card .label {
  font-size: 24rpx;
  opacity: 0.8;
}

.points-card .points {
  font-size: 60rpx;
  font-weight: bold;
  margin-top: 10rpx;
}

.actions {
  display: flex;
  justify-content: space-around;
  padding: 40rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
}

.admin-btn {
  margin: 40rpx;
  padding: 20rpx;
  background: #ff4d4f;
  color: #fff;
  text-align: center;
  border-radius: 8rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin: 40rpx 0;
}

.input {
  border: 1rpx solid #ddd;
  padding: 20rpx;
  margin: 20rpx;
  border-radius: 8rpx;
  background: #fff;
}

.btn {
  margin: 20rpx;
  background: #1890ff;
  color: #fff;
}

.switch {
  text-align: center;
  color: #1890ff;
  margin: 20rpx;
}

.section {
  margin: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.description {
  width: 100%;
  height: 200rpx;
  border: 1rpx solid #ddd;
  padding: 20rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.list {
  height: 600rpx;
}

.item {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
  display: flex;
  flex-wrap: wrap;
}

.item-desc {
