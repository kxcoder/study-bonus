}

.prize-list {
  height: calc(100vh - 200rpx);
}

.prize-item {
  display: flex;
  padding: 20rpx;
  background: #fff;
  margin: 10rpx;
  border-radius: 8rpx;
}

.prize-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
  background: #eee;
}

.prize-info {
  flex: 1;
