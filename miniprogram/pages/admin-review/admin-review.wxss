.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.list {
  height: calc(100vh - 100rpx);
}

.tabs {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff;
}

.tab-group {
  display: flex;
  gap: 20rpx;
}

.tab {
  padding: 12rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
}

.tab.active {
  background: #1890ff;
  color: #fff;
}

.filter-btn {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
}

.item {
  display: flex;
  flex-direction: column;
  background: #fff;
  padding: 24rpx;
  margin: 16rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.item-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-type {
  font-size: 24rpx;
  color: #1890ff;
  margin-right: 8rpx;
}

.item-user {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.item-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-approved {
  background: #f6ffed;
  color: #52c41a;
}

.status-rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.item-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.item-footer {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.item-date {
  font-size: 22rpx;
  color: #999;
}

.item-points {
  font-size: 24rpx;
  color: #52c41a;
  font-weight: bold;
}

.item-reason {
  font-size: 22rpx;
  color: #ff4d4f;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

.load-more {
  text-align: center;
  padding: 24rpx;
  color: #1890ff;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.modal-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
}

.modal-body {
  margin-bottom: 32rpx;
}

.modal-desc {
  display: block;
  margin-bottom: 16rpx;
  color: #666;
  font-size: 28rpx;
  word-wrap: break-word;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 80rpx;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
}

.btn {
  flex: 1;
  padding: 16rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  color: #666;
  border: none;
}

.btn-primary {
  background: #1890ff;
  color: #fff;
}