<view class="container">
  <view class="header">
    <image class="avatar" src="/images/avatar.png" mode="aspectFill"></image>
    <text class="nickname">{{userInfo.nickname}}</text>
  </view>

  <view class="points-card">
    <text class="label">我的积分</text>
    <text class="points">{{pointsBalance}}</text>
  </view>

  <view class="actions">
    <view class="action-btn" bindtap="goToReward">
      <image class="action-icon" src="/images/reward.png"></image>
      <text>记录奖励</text>
    </view>
    <view class="action-btn" bindtap="goToPrize">
      <image class="action-icon" src="/images/prize.png"></image>
      <text>兑换奖品</text>
    </view>
  </view>

  <view class="admin-btn" wx:if="{{isAdmin}}" bindtap="goToAdmin">
    <text>管理后台</text>
  </view>
</view>