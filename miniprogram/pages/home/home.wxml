<view class="container">
  <view wx:if="{{loading}}" class="loading-container">
    <text>加载中...</text>
  </view>
  <view wx:else>
    <view class="header">
      <view class="avatar-wrapper" bindtap="chooseAvatar">
        <image class="avatar" src="{{userInfo.avatar || '/images/avatar.png'}}" mode="aspectFill"></image>
        <view class="avatar-edit-icon">✎</view>
      </view>
      <text class="nickname">{{userInfo ? userInfo.nickname : '加载中'}}</text>
      <text class="edit-nickname" bindtap="editNickname">编辑</text>
    </view>

    <view wx:if="{{isAdmin}}">
      <view class="entry-list">
        <view class="entry-item" bindtap="goToReview">
          <view class="entry-icon review-icon">
            <text class="icon-text">审</text>
          </view>
          <view class="entry-info">
            <text class="entry-title">审核管理</text>
            <text class="entry-desc">查看待审核/已审核记录</text>
          </view>
          <view class="entry-arrow">></view>
        </view>

        <view class="entry-item" bindtap="goToAdminPrize">
          <view class="entry-icon prize-icon">
            <text class="icon-text">奖</text>
          </view>
          <view class="entry-info">
            <text class="entry-title">奖品管理</text>
            <text class="entry-desc">配置奖品和库存</text>
          </view>
          <view class="entry-arrow">></view>
        </view>

        <view class="entry-item" bindtap="goToUserManagement" wx:if="{{userInfo && userInfo.role === 'super_admin'}}">
          <view class="entry-icon user-icon">
            <text class="icon-text">用</text>
          </view>
          <view class="entry-info">
            <text class="entry-title">用户管理</text>
          </view>
          <view class="entry-arrow">></view>
        </view>
      </view>
    </view>

    <view wx:else>
      <view class="points-card">
        <view class="points-row">
          <view class="points-main">
            <text class="label">可用积分</text>
            <text class="points">{{pointsBalance - frozenBalance}}</text>
          </view>
          <view class="points-frozen" wx:if="{{frozenBalance > 0}}">
            <text class="frozen-label">冻结中</text>
            <text class="frozen-value">{{frozenBalance}}</text>
          </view>
        </view>
      </view>

      <view class="actions">
        <view class="action-btn" bindtap="goToReward">
          <image class="action-icon" src="/images/reward.png"></image>
          <text>记录奖励</text>
        </view>
        <view class="action-btn" bindtap="goToPrize">
          <image class="action-icon" src="/images/prize.png"></image>
          <text>兑换奖品</text>
        </view>
      </view>
    </view>

    <view class="modal" wx:if="{{showNicknameModal}}">
      <view class="modal-mask" bindtap="hideNicknameModal"></view>
      <view class="modal-content">
        <view class="modal-header">
          <text class="modal-title">修改昵称</text>
        </view>
        <view class="modal-body">
          <input class="form-input" placeholder="请输入昵称" value="{{nicknameInput}}" bindinput="inputNickname" />
        </view>
        <view class="modal-footer">
          <button class="btn" bindtap="hideNicknameModal">取消</button>
          <button class="btn btn-primary" bindtap="saveNickname" disabled="{{saving}}">{{saving ? '保存中...' : '确定'}}</button>
        </view>
      </view>
    </view>

    <view class="modal" wx:if="{{showAvatarModal}}">
      <view class="modal-mask" bindtap="hideAvatarModal"></view>
      <view class="modal-content avatar-modal">
        <view class="modal-header">
          <text class="modal-title">选择头像</text>
        </view>
        <view class="avatar-grid">
          <block wx:for="{{avatarList}}" wx:key="index">
            <view class="avatar-item {{selectedAvatar === item ? 'selected' : ''}}" bindtap="selectAvatar" data-avatar="{{item}}">
              <image src="{{item}}" mode="aspectFill"></image>
            </view>
          </block>
        </view>
        <view class="modal-footer">
          <button class="btn" bindtap="hideAvatarModal">取消</button>
          <button class="btn btn-primary" bindtap="saveAvatar" disabled="{{saving}}">{{saving ? '保存中...' : '确定'}}</button>
        </view>
      </view>
    </view>
  </view>
</view>