<view class="container">
  <view class="section">
    <textarea class="description" placeholder="描述你的成就..." bindinput="inputDescription" value="{{description}}"></textarea>
    <button class="btn" bindtap="submitReward">提交申请</button>
  </view>

  <view class="section">
    <text class="section-title">申请记录</text>
    <scroll-view scroll-y class="list">
      <block wx:for="{{rewards}}" wx:key="id">
        <view class="item">
          <text class="item-desc">{{item.description}}</text>
          <view class="item-footer">
            <text class="item-status status-{{item.status}}">{{statusText[item.status]}}</text>
            <text wx:if="{{item.status === 'approved' && item.points}}" class="item-points">+{{item.points}}积分</text>
            <text wx:if="{{item.status === 'rejected' && item.admin_note}}" class="item-reason">拒绝原因: {{item.admin_note}}</text>
          </view>
        </view>
      </block>
      <view wx:if="{{rewards.length === 0}}" class="empty">
        <text>暂无记录</text>
      </view>
    </scroll-view>
  </view>
</view>