<view class="container">
  <block wx:if="{{isFirstLogin}}">
    <view class="title">首次登录请修改密码</view>
    <input class="input" password placeholder="新密码（至少6位）" bindinput="inputPassword"></input>
    <input class="input" password placeholder="确认密码" bindinput="inputConfirmPassword"></input>
    <button class="btn" bindtap="changePassword">确认修改</button>
  </block>

  <block wx:else>
    <view class="title">登录</view>

    <block wx:if="{{loginType === 'wechat'}}">
      <input class="input" placeholder="昵称（选填）" bindinput="inputNickname"></input>
      <button class="btn" bindtap="wechatLogin">微信快速登录</button>
      <view class="switch" bindtap="switchLoginType">使用账号密码登录</view>
    </block>

    <block wx:else>
      <input class="input" placeholder="用户名" bindinput="inputUsername"></input>
      <input class="input" password placeholder="密码" bindinput="inputPassword"></input>
      <button class="btn" bindtap="passwordLogin">登录</button>
      <view class="switch" bindtap="switchLoginType">微信登录</view>
    </block>
  </block>
</view>