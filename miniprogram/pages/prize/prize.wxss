.prize-list, .history-list {
  height: calc(100vh - 220rpx);
}

.points-info {
  display: flex;
  justify-content: space-around;
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.points-item {
  text-align: center;
}

.points-label {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.points-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
  display: block;
  margin-top: 10rpx;
}

.points-item.frozen .points-value {
  color: #faad14;
}

.prize-item.inactive {
  opacity: 0.5;
}

.prize-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  margin-right: 20rpx;
}

.prize-info {
  flex: 1;
}

.prize-name {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
}

.prize-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}

.prize-points {
  color: #ff4d4f;
  font-weight: bold;
}

.prize-inventory {
  color: #999;
  font-size: 24rpx;
}

.redeem-btn {
  background: #1890ff;
  color: #fff;
  align-self: center;
}

.prize-item.inactive .redeem-btn {
  background: #ccc;
}

.history-item {
  background: #fff;
  padding: 30rpx;
  margin: 10rpx 20rpx;
  border-radius: 12rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.history-name {
  font-size: 32rpx;
  font-weight: bold;
}

.history-points {
  color: #ff4d4f;
  font-weight: bold;
}

.history-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-text {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.status-text.pending {
  background: #fff7e6;
  color: #faad14;
}

.status-text.approved {
  background: #f6ffed;
  color: #52c41a;
}

.status-text.rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.history-date {
  font-size: 24rpx;
  color: #999;
}

.history-reason {
  margin-top: 12rpx;
}

.item-footer {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.item-footer .item-status {
  margin-right: 10rpx;
}
