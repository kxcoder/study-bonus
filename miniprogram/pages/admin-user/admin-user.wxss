.user-list {
  height: calc(100vh - 100rpx);
}

.user-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 24rpx;
  margin: 10rpx 20rpx;
  border-radius: 12rpx;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-tags {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.user-role {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-right: 10rpx;
}

.role-child {
  background: #e0f7f4;
  color: #00a99d;
}

.role-admin {
  background: #e6f7ff;
  color: #1890ff;
}

.role-super_admin {
  background: #fff1f0;
  color: #ff4d4f;
}

.user-assigned {
  font-size: 22rpx;
  color: #52c41a;
  background: #f6ffed;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.user-actions {
  display: flex;
  flex-wrap: nowrap;
  margin-left: 16rpx;
}

.user-actions button {
  margin-left: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

.user-actions button:first-child {
  margin-left: 0;
}

.assign-user {
  display: block;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.picker-input {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
}

.role-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.role-btn {
  flex: 1;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  border: 2rpx solid #f5f5f5;
}

.role-btn.active {
  background: #e6f7ff;
  border-color: #1890ff;
  color: #1890ff;
}